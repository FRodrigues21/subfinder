# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USERNAME=subfinder
DB_PASSWORD=change_me_strong_password

# ── OpenSubtitles API ─────────────────────────────────────────────────────────
# Get your free API key at: https://www.opensubtitles.com/consumers
OPENSUBTITLES_API_KEY=your_api_key_here
OPENSUBTITLES_APP_NAME=SubFinder
OPENSUBTITLES_APP_VERSION=1.0.0

# ── Rails ─────────────────────────────────────────────────────────────────────
# Generate with: bundle exec rails secret
SECRET_KEY_BASE=generate_a_long_random_secret_here
RAILS_ENV=production

# Set to "true" if you have HTTPS configured (recommended in production)
FORCE_SSL=false

# ── Optional ──────────────────────────────────────────────────────────────────
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true
